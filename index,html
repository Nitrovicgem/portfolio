    <style>
        :root {
            --neon-blue: #00d4ff;
            --neon-purple: #b829dd;
            --dark-bg: #0a0a0f;
            --card-bg: #151520;
            --text-primary: #ffffff;
            --text-secondary: #a0a0b0;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Rajdhani', sans-serif;
            background: var(--dark-bg);
            color: var(--text-primary);
            overflow-x: hidden;
            line-height: 1.6;
        }
        .bg-animation {
            position: fixed; top: 0; left: 0;
            width: 100%; height: 100%; z-index: -1;
            background: 
                radial-gradient(circle at 20% 50%, rgba(0, 212, 255, 0.15) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(184, 41, 221, 0.15) 0%, transparent 50%);
            animation: bgPulse 8s ease-in-out infinite;
        }
        @keyframes bgPulse {
            0%, 100% { opacity: 0.5; transform: scale(1); }
            50% { opacity: 0.8; transform: scale(1.05); }
        }
        nav {
            position: fixed; top: 0; width: 100%;
            padding: 20px 50px;
            display: flex; justify-content: space-between; align-items: center;
            z-index: 1000;
            background: rgba(10, 10, 15, 0.8);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0, 212, 255, 0.2);
        }
        .logo {
            font-family: 'Orbitron', sans-serif; font-size: 1.5rem; font-weight: 900;
            background: linear-gradient(135deg, var(--neon-blue), var(--neon-purple));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            text-transform: uppercase; letter-spacing: 2px;
        }
        .hero {
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
            padding: 100px 50px;
        }
        .hero-content { text-align: center; max-width: 900px; }
        .hero h1 {
            font-family: 'Orbitron', sans-serif; font-size: clamp(2.5rem, 6vw, 4.5rem);
            font-weight: 900; margin-bottom: 20px;
            background: linear-gradient(135deg, #fff, var(--neon-blue), var(--neon-purple));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        .hero p { font-size: 1.3rem; color: var(--text-secondary); margin-bottom: 40px; }
        .btn {
            padding: 15px 40px; font-family: 'Orbitron', sans-serif;
            font-size: 1rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: 1px; text-decoration: none; display: inline-block;
            transition: all 0.3s;
        }
        .btn-primary {
            background: linear-gradient(135deg, var(--neon-blue), var(--neon-purple));
            color: white; clip-path: polygon(10% 0, 100% 0, 90% 100%, 0% 100%);
        }
        .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(0, 212, 255, 0.4); }
        section { padding: 100px 50px; max-width: 1400px; margin: 0 auto; }
        .section-header { text-align: center; margin-bottom: 60px; }
        .section-header h2 {
            font-family: 'Orbitron', sans-serif; font-size: 2.5rem; margin-bottom: 15px;
        }
        .work-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 30px; }
        .work-card {
            background: var(--card-bg); border: 1px solid rgba(0, 212, 255, 0.2);
            border-radius: 15px; overflow: hidden; transition: all 0.4s;
        }
        .work-card:hover {
            transform: translateY(-10px); border-color: var(--neon-blue);
            box-shadow: 0 20px 40px rgba(0, 212, 255, 0.2);
        }
        .video-thumbnail {
            position: relative;
            height: 220px;
            overflow: hidden;
            display: block;
            text-decoration: none;
            cursor: pointer;
            background: linear-gradient(135deg, #1a1a2e, #16213e);
        }
        .video-thumbnail img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s;
        }
        .work-card:hover .video-thumbnail img {
            transform: scale(1.1);
        }
        .play-overlay {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0, 0, 0, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.3s;
        }
        .video-thumbnail:hover .play-overlay {
            background: rgba(0, 0, 0, 0.15);
        }
        .play-button {
            width: 60px;
            height: 60px;
            background: rgba(255, 0, 0, 0.9);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
            box-shadow: 0 4px 20px rgba(0,0,0,0.5);
        }
        .play-button::after {
            content: '';
            width: 0;
            height: 0;
            border-left: 20px solid white;
            border-top: 12px solid transparent;
            border-bottom: 12px solid transparent;
            margin-left: 5px;
        }
        .video-thumbnail:hover .play-button {
            transform: scale(1.1);
            background: rgba(255, 0, 0, 1);
        }
        .work-info { padding: 25px; }
        .work-tags { display: flex; gap: 10px; margin-bottom: 15px; flex-wrap: wrap; }
        .tag {
            padding: 5px 12px; background: rgba(0, 212, 255, 0.1);
            border: 1px solid rgba(0, 212, 255, 0.3); border-radius: 20px;
            font-size: 0.8rem; color: var(--neon-blue);
        }
        .work-info h3 { font-family: 'Orbitron', sans-serif; font-size: 1.3rem; margin-bottom: 10px; }
        .work-info p { color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 20px; }
        .work-links { display: flex; gap: 10px; flex-wrap: wrap; }
        .work-link {
            display: inline-flex; align-items: center; gap: 8px;
            color: var(--neon-blue); text-decoration: none; font-weight: 600;
            transition: all 0.3s; padding: 8px 16px;
            border: 1px solid var(--neon-blue); border-radius: 8px; font-size: 0.9rem;
        }
        .work-link:hover { background: var(--neon-blue); color: white; }
        .skills-container { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 30px; }
        .skill-category {
            background: var(--card-bg); border: 1px solid rgba(0, 212, 255, 0.2);
            border-radius: 15px; padding: 30px;
        }
        .skill-category h3 { font-family: 'Orbitron', sans-serif; color: var(--neon-blue); margin-bottom: 15px; }
        .skill-list { list-style: none; }
        .skill-list li { padding: 8px 0; color: var(--text-secondary); }
        .contact {
            text-align: center; background: linear-gradient(135deg, rgba(0, 212, 255, 0.05), rgba(184, 41, 221, 0.05));
